# =============================================
# Scott Windsor Realty — Environment Variables
# Copy this file to .env and fill in values
# =============================================

# Database (SQLite — do not change the path format)
DATABASE_URL="file:./dev.db"

# NextAuth (generate a random secret: openssl rand -base64 32)
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="https://yoursite.com"

# Admin Login Credentials
ADMIN_EMAIL="windsorinfinity@gmail.com"
# Plain text for dev, bcrypt hash for production
# Generate hash: node -e "const b = require('bcryptjs'); console.log(b.hashSync('yourpassword', 12))"
ADMIN_PASSWORD="your-password-or-bcrypt-hash"

# Public Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://yoursite.com"

# Agent Info (shown in header, footer, forms)
NEXT_PUBLIC_AGENT_NAME="Scott Windsor"
NEXT_PUBLIC_AGENT_PHONE="513-307-6449"
NEXT_PUBLIC_AGENT_EMAIL="windsorinfinity@gmail.com"
NEXT_PUBLIC_BROKERAGE="Align Right Realty Infinity"

# Google Tag Manager (optional — leave blank to disable)
NEXT_PUBLIC_GTM_ID=""

# IDX Integration (from your IDX provider — iframe embed URL)
NEXT_PUBLIC_IDX_SRC=""

# Go High Level
GHL_WEBHOOK_URL=""
# GHL Calendar embed ID (optional)
NEXT_PUBLIC_GHL_CALENDAR_ID=""

# Resend — email notifications for new leads (free up to 3,000/mo)
# Sign up at resend.com, verify your domain, get API key
RESEND_API_KEY=""
RESEND_FROM_EMAIL="leads@scottwindsorhomes.com"
NOTIFY_EMAIL="windsorinfinity@gmail.com"

# Uploadthing (for image uploads in admin)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Lofty CRM — pulls Scott's active MLS listings (24-hr cache)
# Get your key at developer.lofty.com
LOFTY_API_KEY=""
LOFTY_AGENT_ID="210708"
